# ─── Database ────────────────────────────────────────────────────────────────
# XAMPP default (sin contraseña): mysql://root:@localhost:3306/melaniapp
# MySQL Community Server (con contraseña): mysql://root:PASSWORD@localhost:3306/melaniapp
DATABASE_URL="mysql://root:@localhost:3306/melaniapp"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Genera strings aleatorios largos para producción
JWT_SECRET="cambia-este-secreto-jwt-super-seguro"
JWT_REFRESH_SECRET="cambia-este-secreto-refresh-super-seguro"

# Duración tokens
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
