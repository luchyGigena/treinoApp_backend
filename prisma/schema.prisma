generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ClientType {
  GYM
  PERSONAL_TRAINER
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  nombre    String?
  apellido  String?
  telefono  String?
  email     String   @unique
  password  String
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relación cliente ↔ alumnos (self-referential)
  alumnos   User[]  @relation("ClienteAlumnos")
  cliente   User?   @relation("ClienteAlumnos", fields: [clienteId], references: [id])
  clienteId Int?

  // Perfil de negocio (solo para usuarios con rol CLIENTE)
  perfilCliente ClientePerfil?

  routines      Routine[]
  weightLogs    WeightLog[]
  workoutLogs   WorkoutLog[]
  refreshTokens RefreshToken[]
}

model ClientePerfil {
  id         Int        @id @default(autoincrement())
  userId     Int        @unique
  user       User       @relation(fields: [userId], references: [id])
  clientType ClientType

  // ── Entrenador Personal ──────────────────────────────────
  nombre        String?
  apellido      String?
  emailContacto String?

  // ── Gimnasio ─────────────────────────────────────────────
  nombreComercial     String?
  responsableNombre   String?
  responsableApellido String?

  // ── Compartidos ──────────────────────────────────────────
  cuit      String?
  direccion String?
  telefono  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Routine {
  id        Int      @id @default(autoincrement())
  name      String
  alumnoId  Int
  alumno    User     @relation(fields: [alumnoId], references: [id])
  days      Json
  createdAt DateTime @default(now())

  workoutLogs WorkoutLog[]
}

model WeightLog {
  id        Int      @id @default(autoincrement())
  alumnoId  Int
  alumno    User     @relation(fields: [alumnoId], references: [id])
  date      String
  weight    Decimal  @db.Decimal(5, 2)
  notes     String?
  createdAt DateTime @default(now())
}

model WorkoutLog {
  id        Int      @id @default(autoincrement())
  alumnoId  Int
  alumno    User     @relation(fields: [alumnoId], references: [id])
  routineId Int
  routine   Routine  @relation(fields: [routineId], references: [id])
  date      String
  exercises Json
  createdAt DateTime @default(now())

  @@unique([alumnoId, date, routineId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}
